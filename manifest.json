{
  "manifest_version": 3,
  "name": "SnapTeX — Screenshot Bag",
  "version": "1.0.0",
  "description": "Capture screenshots into a bag and stitch them into one tall image. Plus LaTeX to Unicode converter.",
  "permissions": [
    "activeTab",
    "scripting",
    "tabs",
    "storage",
    "unlimitedStorage"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "SnapTeX"
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_start"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["equation.html", "equation.js", "mathjax.js"],
      "matches": ["<all_urls>"]
    }
  ]
}